{
  "name": "collaborative-canvas",
  "version": "1.0.0",
  "description": "Real-time collaborative drawing canvas using HTML5 Canvas and native WebSockets.",
  "main": "dist/server/server.js",
  "type": "module",
  "scripts": {
    "start": "node dist/server/server.js",
    "build:client": "tsc -p client/tsconfig.json",
    "build:server": "tsc -p tsconfig.json",
    "build": "npm run build:client && npm run build:server",
    "dev:server": "tsx watch server/server.ts",
    "dev:client": "tsc -p client/tsconfig.json --watch"
  },
  "dependencies": {
    "express": "^4.19.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.12",
    "@types/ws": "^8.5.12",
    "tsx": "^4.15.0",
    "typescript": "^5.4.5"
  }
}
